{
  "name": "@eleven-am/pondsocket-nest",
  "version": "0.0.138",
  "description": "NestJS decorators and dependency-injection integration for PondSocket.",
  "keywords": [
    "pondsocket",
    "nestjs",
    "websocket",
    "sse",
    "realtime",
    "decorators"
  ],
  "author": "Roy OSSAI",
  "license": "GPL-3.0",
  "homepage": "https://github.com/eleven-am/pondsocket#readme",
  "bugs": {
    "url": "https://github.com/eleven-am/pondsocket/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eleven-am/pondsocket.git",
    "directory": "javascript/nest"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc --project tsconfig.json",
    "test": "jest --runInBand",
    "lint": "eslint src --max-warnings=0",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@eleven-am/pondsocket": "^0.1.219",
    "@eleven-am/pondsocket-common": "^0.0.41",
    "reflect-metadata": "^0.2.2"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "rxjs": "^7.1.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.test\\.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.test.json"
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.test.ts",
      "!**/index.ts"
    ],
    "coverageDirectory": "../coverage/nest",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@eleven-am/pondsocket$": "<rootDir>/../../core/dist",
      "^@eleven-am/pondsocket/types$": "<rootDir>/../../core/dist",
      "^@eleven-am/pondsocket-common$": "<rootDir>/../../comnon/dist"
    }
  }
}
