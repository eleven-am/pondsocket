{
  "name": "pondsocket-monorepo",
  "private": true,
  "packageManager": "npm@11.18.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "workspaces": [
    "comnon",
    "core",
    "client",
    "express",
    "nest"
  ],
  "scripts": {
    "clean": "npm run clean --workspaces --if-present && rimraf coverage .pack",
    "build": "npm run build --workspaces --if-present",
    "build:common": "npm run build --workspace @eleven-am/pondsocket-common",
    "build:core": "npm run build --workspace @eleven-am/pondsocket",
    "build:client": "npm run build --workspace @eleven-am/pondsocket-client",
    "build:express": "npm run build --workspace @eleven-am/pondsocket-express",
    "build:nest": "npm run build --workspace @eleven-am/pondsocket-nest",
    "test": "npm run test --workspaces --if-present",
    "test:common": "npm test --workspace @eleven-am/pondsocket-common",
    "test:core": "npm test --workspace @eleven-am/pondsocket",
    "test:client": "npm test --workspace @eleven-am/pondsocket-client",
    "test:express": "npm test --workspace @eleven-am/pondsocket-express",
    "test:nest": "npm test --workspace @eleven-am/pondsocket-nest",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "npm run build && tsc --project tsconfig.type-tests.json --noEmit",
    "pack:check": "node scripts/verify-packages.mjs",
    "validate": "npm run lint && npm run typecheck && npm test && npm run pack:check",
    "release": "node scripts/publish-packages.mjs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.43",
    "@types/ws": "^8.18.1",
    "eslint": "^10.6.0",
    "express": "^5.2.1",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
