{
  "name": "@eleven-am/pondsocket-common",
  "version": "0.0.41",
  "description": "Shared protocol, schema, routing, and observable primitives for PondSocket.",
  "keywords": [
    "pondsocket",
    "websocket",
    "realtime",
    "schema",
    "presence",
    "pubsub"
  ],
  "author": "Roy OSSAI",
  "license": "GPL-3.0",
  "homepage": "https://github.com/eleven-am/pondsocket#readme",
  "bugs": {
    "url": "https://github.com/eleven-am/pondsocket/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eleven-am/pondsocket.git",
    "directory": "javascript/comnon"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc --project tsconfig.json",
    "test": "jest --coverage --verbose",
    "lint": "eslint src --max-warnings=0",
    "prepack": "npm run build"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.test\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.test.ts",
      "!**/index.ts"
    ],
    "coverageDirectory": "../coverage/common",
    "testEnvironment": "node"
  }
}
