{
  "name": "@eleven-am/pondsocket-client",
  "version": "0.0.39",
  "description": "Typed browser and Node.js client for PondSocket.",
  "keywords": [
    "pondsocket",
    "websocket",
    "sse",
    "realtime",
    "client",
    "presence"
  ],
  "author": "Roy OSSAI",
  "license": "GPL-3.0",
  "homepage": "https://github.com/eleven-am/pondsocket#readme",
  "bugs": {
    "url": "https://github.com/eleven-am/pondsocket/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eleven-am/pondsocket.git",
    "directory": "javascript/client"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "commonjs",
  "main": "./dist/node-entry.js",
  "browser": "./dist/browser-entry.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/browser-entry.js",
      "node": "./dist/node-entry.js",
      "require": "./dist/node-entry.js",
      "default": "./dist/browser-entry.js"
    },
    "./browser": {
      "types": "./dist/browser-entry.d.ts",
      "require": "./dist/browser-entry.js",
      "default": "./dist/browser-entry.js"
    },
    "./node": {
      "types": "./dist/node-entry.d.ts",
      "require": "./dist/node-entry.js",
      "default": "./dist/node-entry.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc --project tsconfig.json",
    "test": "jest --coverage --verbose",
    "lint": "eslint src --max-warnings=0",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@eleven-am/pondsocket-common": "^0.0.41",
    "ws": "^8.21.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.test\\.ts$",
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "diagnostics": false
        }
      ]
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.test.ts",
      "!**/index.ts",
      "!**/*-entry.ts"
    ],
    "coverageDirectory": "../coverage/client",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@eleven-am/pondsocket-common$": "<rootDir>/../../comnon/dist"
    }
  }
}
