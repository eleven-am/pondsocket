{
  "name": "@eleven-am/pondsocket-express",
  "version": "0.0.42",
  "description": "Express integration for the PondSocket server.",
  "keywords": [
    "pondsocket",
    "express",
    "websocket",
    "sse",
    "realtime"
  ],
  "author": "Roy OSSAI",
  "license": "GPL-3.0",
  "homepage": "https://github.com/eleven-am/pondsocket#readme",
  "bugs": {
    "url": "https://github.com/eleven-am/pondsocket/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eleven-am/pondsocket.git",
    "directory": "javascript/express"
  },
  "engines": {
    "node": ">=20"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsc --project tsconfig.json",
    "test": "jest --coverage --verbose --passWithNoTests",
    "lint": "eslint src --max-warnings=0",
    "prepack": "npm run build"
  },
  "dependencies": {
    "@eleven-am/pondsocket": "^0.1.219"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.test\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.ts",
      "!**/*.test.ts"
    ],
    "coverageDirectory": "../coverage/express",
    "testEnvironment": "node"
  }
}
